# Abaqus Environment Configuration
# Auto-load MCP Plugin on startup
#
# Installation:
#   Copy this file to your home directory and rename to abaqus_v6.env
#   Windows: C:\Users\YourUsername\abaqus_v6.env
#   Linux/Mac: ~/abaqus_v6.env

import os
import sys

def onCaeStartup():
    """Called when Abaqus/CAE starts"""
    import io
    mcp_home = os.path.expanduser('~/.abaqus-mcp')
    mcp_plugin = os.path.join(mcp_home, 'abaqus_mcp_plugin.py')
    
    if os.path.exists(mcp_plugin):
        # Get the main module's namespace
        import __main__
        with open(mcp_plugin, 'rb') as f:
            code = f.read()
        if sys.version_info[0] >= 3:
            code = code.decode('utf-8')
        exec(code, __main__.__dict__)
