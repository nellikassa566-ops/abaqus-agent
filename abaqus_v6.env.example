# Abaqus Environment Configuration
# Auto-load MCP Plugin on startup
#
# Installation:
#   Copy this file to your home directory and rename to abaqus_v6.env
#   Windows: C:\Users\YourUsername\abaqus_v6.env
#   Linux/Mac: ~/abaqus_v6.env

import os
import sys

def onCaeStartup():
    """Called when Abaqus/CAE starts"""
    import io

    mcp_home = None
    for env_name in ('ABAQUS_AGENT_HOME', 'ABAQUS_MCP_HOME'):
        env_home = os.environ.get(env_name)
        if env_home:
            candidate = os.path.abspath(os.path.expanduser(env_home))
            if os.path.exists(os.path.join(candidate, 'abaqus_mcp_plugin.py')):
                mcp_home = candidate
                break

    if mcp_home is None:
        for folder_name in ('.abaqus-agent', '.abaqus-mcp'):
            candidate = os.path.join(os.path.expanduser('~'), folder_name)
            if os.path.exists(os.path.join(candidate, 'abaqus_mcp_plugin.py')):
                mcp_home = candidate
                break

    if mcp_home is None:
        return

    os.environ.setdefault('ABAQUS_AGENT_HOME', mcp_home)
    os.environ.setdefault('ABAQUS_MCP_HOME', mcp_home)
    mcp_plugin = os.path.join(mcp_home, 'abaqus_mcp_plugin.py')
    
    if os.path.exists(mcp_plugin):
        # Get the main module's namespace
        import __main__
        with open(mcp_plugin, 'rb') as f:
            code = f.read()
        if sys.version_info[0] >= 3:
            code = code.decode('utf-8')
        exec(code, __main__.__dict__)
